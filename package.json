{
  "name": "royale-launcher-electron",
  "version": "0.1.0",
  "private": true,
  "author": "sqwat",
  "description": "Royale desktop launcher built with Electron and React",
  "productName": "Royale Launcher",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && set ELECTRON_RUN_AS_NODE=&& set VITE_DEV_SERVER_URL=http://127.0.0.1:5173&& electron .\"",
    "build": "vite build",
    "client:pack": "node scripts/build-client-package.mjs",
    "client:pack:1.21.11": "node scripts/build-client-package.mjs 1.21.11",
    "start": "npm run build && set ELECTRON_RUN_AS_NODE=&& electron .",
    "dist:win": "npm run dist:win:setup",
    "dist:win:setup": "npm run build && electron-builder --win nsis",
    "dist:win:portable": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "yauzl": "^3.2.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^37.2.0",
    "electron-builder": "^26.8.1",
    "vite": "^5.4.10",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.royale.launcher",
    "productName": "Royale Launcher",
    "asar": true,
    "compression": "maximum",
    "electronLanguages": [
      "en-US",
      "ru"
    ],
    "directories": {
      "output": "dist-app",
      "buildResources": "build"
    },
    "files": [
      "dist-renderer/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "icon.ico",
      "signAndEditExecutable": false,
      "artifactName": "RoyaleLauncher-${version}.exe",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    }
  }
}
